# Copy to .env (gitignored). Before `npm run deploy`, load it with:
#   set -a && source .env && set +a
# (plain `export $(cat .env | xargs)` breaks on the comment lines above).
# For CI, these are set as GitHub Actions secrets instead.

# Scaleway account credentials (Console -> Identity and Access Management -> API keys)
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXX
SCW_SECRET_KEY=00000000-0000-0000-0000-000000000000
SCW_DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
SCW_DEFAULT_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Injected into the deployed functions as a namespace secret by deploy.sh.
# (Resend Audience IDs are not secrets - they're hardcoded constants in
# functions/newsletter.js instead.)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
