# Copy to .env (gitignored) and `export $(cat .env | xargs)` before `npm run deploy`
# locally, or set these as GitHub Actions secrets for the CI deploy workflow.

# Scaleway account credentials (Console -> Identity and Access Management -> API keys)
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXX
SCW_SECRET_KEY=00000000-0000-0000-0000-000000000000
SCW_DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
SCW_DEFAULT_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Injected into the deployed functions as namespace secrets by deploy.sh
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000
