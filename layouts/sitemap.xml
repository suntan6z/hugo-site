{{- $excluded := slice "privacy-policy" "categories" -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Site.Pages }}
  {{- $path := strings.TrimPrefix "/" .RelPermalink | strings.TrimSuffix "/" }}
  {{- if not (in $excluded $path) }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02" }}</lastmod>
    {{- end }}
    <changefreq>{{- if eq .Kind "home" }}weekly{{- else if eq .Section "blog" }}monthly{{- else }}yearly{{- end }}</changefreq>
    <priority>{{- if eq .Kind "home" }}1.0{{- else if eq .Kind "section" }}0.7{{- else if eq .Section "blog" }}0.8{{- else }}0.6{{- end }}</priority>
  </url>
  {{- end }}
  {{- end }}
</urlset>
