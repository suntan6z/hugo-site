{{- $pagesCount := 20 -}}
{{- $pages := .Pages -}}
{{- if eq .Kind "home" }}{{ $pages = .Site.RegularPages }}{{ end -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if eq .Title .Site.Title }}{{ .Site.Title }}{{ else }}{{ with .Title }}{{ . }} – {{ end }}{{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Site.Params.description }}{{ . }}{{ else }}Recent content on {{ .Site.Title }}{{ end }}</description>
    <managingEditor>{{ .Site.Params.email }} ({{ .Site.Params.author }})</managingEditor>
    <language>{{ .Site.Language.Lang }}</language>
    <copyright>© {{ now.Year }} {{ .Site.Params.author }}</copyright>
    <lastBuildDate>{{ with $pages }}{{ (index . 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}{{ end }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}feed.xml" rel="self" type="application/rss+xml" />
    {{ range first $pagesCount $pages }}
    <item>
      <title>{{ .Title | html }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      {{ with .Params.category }}<category>{{ . }}</category>{{ end }}
      <description>{{ .Summary | html }}</description>
    </item>
    {{ end }}
  </channel>
</rss>
